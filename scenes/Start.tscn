[node name="HelpText" type="Label" parent="UI/HelpPanel"]
offset_left = 540
offset_top = 160
offset_right = 1380
offset_bottom = 920
text = "=== 迷宫探索者 ===

↑↓/点击→选择  Enter→玩法
U→排行榜  V→说明  Esc→退出

=== 游戏内 ===

WASD/方向键→移动  Esc→暂停
左键小地图→放大  Z→作弊

=== 多人联机 ===

创建房间→生成6位房间码
合作:携手找出口  比赛:谁先到谁赢
E键→传送队友"
theme_override_font_sizes/font_size = 15

